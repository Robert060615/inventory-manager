# MongoDB connection string — e.g. mongodb://localhost:27017/inventariehanterare or a MongoDB Atlas URI
MONGODB_URI=

# Secret used to sign and verify JWT tokens — use a long, random string in production
JWT_SECRET=

# Port the Express server listens on (defaults to 3000 if omitted)
PORT=3000

# Set to 'production' to enable secure (HTTPS-only) cookies — Vercel sets this automatically
NODE_ENV=development

# Admin account created by npm run seed
SEED_EMAIL=
# Required — seed will exit with an error if this is missing
SEED_PASSWORD=
