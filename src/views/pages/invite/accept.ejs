<div class="login-wrapper">
  <div class="login-card">
    <h1>Skapa konto</h1>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (invite) { %>
      <form method="POST" action="/invite/accept/<%= invite.token %>">
        <div class="form-group">
          <label for="email">E-postadress</label>
          <input type="email" id="email" name="email" value="<%= invite.email %>" readonly>
        </div>

        <div class="form-group">
          <label for="password">Lösenord</label>
          <input type="password" id="password" name="password" required autofocus placeholder="Minst 6 tecken">
        </div>

        <button type="submit" class="btn btn-primary">Skapa konto</button>
      </form>
    <% } %>
  </div>
</div>
