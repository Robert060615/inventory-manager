<div class="form-page">
  <h1>Bjud in användare</h1>
  <p class="form-desc">Ange e-postadressen till den du vill bjuda in. En inbjudningslänk genereras som du kan kopiera och skicka manuellt.</p>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="/invite">
    <div class="form-group">
      <label for="email">E-postadress</label>
      <input type="email" id="email" name="email" required autofocus placeholder="ny@email.se">
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Bjud in</button>
    </div>
  </form>
</div>
