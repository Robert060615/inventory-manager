<div class="form-page">
  <h1>Redigera produkt</h1>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="/products/<%= product._id %>/update">
    <div class="form-group" id="name-group">
      <label for="name">Namn</label>
      <input type="text" id="name" name="name" value="<%= product.name %>" autofocus>
    </div>

    <div class="form-group">
      <label for="category">Kategori</label>
      <select id="category" name="category" required onchange="toggleName(this.value)">
        <option value="">Välj kategori</option>
        <% categories.forEach(cat => { %>
          <option value="<%= cat %>" <%= product.category === cat ? 'selected' : '' %>><%= cat %></option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="size">Storlek</label>
      <select id="size" name="size">
        <% sizes.forEach(s => { %>
          <option value="<%= s %>" <%= product.size === s ? 'selected' : '' %>><%= s || '–' %></option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="quantity">Antal</label>
      <input type="number" id="quantity" name="quantity" value="<%= product.quantity %>" min="0" required>
    </div>

    <div class="form-group">
      <label for="image">Bild (URL eller sökväg, valfritt)</label>
      <input type="text" id="image" name="image" value="<%= product.image || '' %>" placeholder="https://... eller /uploads/bild.jpg">
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Spara ändringar</button>
      <a href="/products" class="btn btn-secondary">Avbryt</a>
    </div>
  </form>
</div>

<script>
  function toggleName(category) {
    const group = document.getElementById('name-group')
    const input = document.getElementById('name')
    const isOverall = category === 'Overall'
    group.style.display = isOverall ? 'none' : ''
    input.required = !isOverall
    if (isOverall) input.value = ''
  }
  toggleName('<%= product.category %>')
</script>
