<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> – SPIIK Inventariehanterare</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <span class="navbar-brand">SPIIK Inventariehanterare</span>
    <div class="navbar-links">
      <% if (locals.user) { %>
        <a href="/products">Produkter</a>
        <a href="/invite">Bjud in</a>
        <span class="nav-email"><%= user.email %></span>
        <a href="/auth/logout">Logga ut</a>
      <% } else { %>
        <a href="/auth/login">Logga in</a>
      <% } %>
    </div>
  </nav>

  <main class="container">
    <%- body %>
  </main>
</body>
</html>
